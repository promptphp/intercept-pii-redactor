{
    "name": "promptphp/intercept-pii-redactor",
    "description": "PII redaction middleware for Laravel AI agents.",
    "keywords": ["laravel", "ai", "middleware", "prompt", "prompt-injection", "security"],
    "homepage": "https://intercept.promptphp.com",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Victor Ukam",
            "email": "victorjohnukam@gmail.com",
            "homepage": "https://github.com/veeqtoh",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/ai": "*",
        "promptphp/intercept-support": "*"
    },
    "autoload": {
        "psr-4": {
            "PromptPHP\\Intercept\\PIIRedactor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PromptPHP\\Intercept\\PIIRedactor\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}